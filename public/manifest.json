{
  "name":             "ApnaMap — Walk Your City",
  "short_name":       "ApnaMap",
  "description":      "Walk your city digitally. Find shops, offers, and deals near you.",
  "start_url":        "/explore",
  "scope":            "/",
  "id":               "apnamap-v1",

  "display":          "standalone",
  "display_override": ["standalone", "minimal-ui"],

  "background_color": "#05070C",
  "theme_color":      "#FF5E1A",

  "orientation": "portrait-primary",
  "lang":        "en-IN",
  "dir":         "ltr",

  "categories": ["shopping", "local", "navigation"],

  "icons": [
    {
      "src":     "/api/icon?size=192",
      "sizes":   "192x192",
      "type":    "image/png",
      "purpose": "any"
    },
    {
      "src":     "/api/icon?size=512",
      "sizes":   "512x512",
      "type":    "image/png",
      "purpose": "any"
    },
    {
      "src":     "/api/icon?size=512",
      "sizes":   "512x512",
      "type":    "image/png",
      "purpose": "maskable"
    }
  ],

  "shortcuts": [
    {
      "name":        "Walk View",
      "short_name":  "Walk",
      "description": "Explore shops around you",
      "url":         "/explore",
      "icons": [
        { "src": "/api/icon?size=96", "sizes": "96x96", "type": "image/png" }
      ]
    },
    {
      "name":        "Live Offers",
      "short_name":  "Offers",
      "description": "Browse deals near you",
      "url":         "/offers",
      "icons": [
        { "src": "/api/icon?size=96", "sizes": "96x96", "type": "image/png" }
      ]
    },
    {
      "name":        "My Shop",
      "short_name":  "My Shop",
      "description": "Manage your shop and deals",
      "url":         "/vendor/dashboard",
      "icons": [
        { "src": "/api/icon?size=96", "sizes": "96x96", "type": "image/png" }
      ]
    }
  ],

  "prefer_related_applications": false
}
