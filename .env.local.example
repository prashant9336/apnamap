# ════════════════════════════════════════════════════
# ApnaMap — Environment Variables
#
# STEP 1: Copy this file and rename to .env.local
# STEP 2: Fill in all values below
# STEP 3: NEVER commit .env.local to GitHub
# ════════════════════════════════════════════════════

# ─── SUPABASE (get from supabase.com → Settings → API) ──────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── APP CONFIG ─────────────────────────────────────────────
# Local dev:  http://localhost:3000
# Testing:    https://apnamap.vercel.app   ← set this in Vercel dashboard
# Production: https://apnamap.com          ← change when custom domain is live
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Default city and coordinates (Prayagraj city center)
NEXT_PUBLIC_DEFAULT_CITY=prayagraj
NEXT_PUBLIC_DEFAULT_LAT=25.4358
NEXT_PUBLIC_DEFAULT_LNG=81.8463
